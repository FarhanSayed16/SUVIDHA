# ============================================================
# SUVIDHA — Complete Environment Variables
# Copy this to .env and fill in actual values before running.
# RULE: Never commit .env to Git. All secrets come from here
#       (dev) or MeghRaj Secrets Manager (prod).
# ============================================================

# ── Node Environment ─────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── API Gateway ───────────────────────────────────────────────────────────
GATEWAY_PORT=3000
# Comma-separated allowed CORS origins (kiosk + admin UI)
CORS_ORIGINS=http://localhost:80,http://localhost:8080,http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# ── 6.1 Database (PostgreSQL) ─────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://suvidha:suvidhadev123@suvidha-postgres:5432/suvidha_db
DATABASE_URL_PYTHON=postgresql://suvidha:suvidhadev123@suvidha-postgres:5432/suvidha_db

# Docker postgres service variables (used by postgres:15-alpine image directly)
POSTGRES_DB=suvidha_db
POSTGRES_USER=suvidha
POSTGRES_PASSWORD=suvidhadev123

# ── 6.2 Redis ─────────────────────────────────────────────────────────────
REDIS_URL="redis://:suvidhadev123@suvidha-redis:6379"
# Leave empty for dev; set a strong password in production
REDIS_PASSWORD=suvidhadev123

# ── 6.3 Auth & JWT ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=a7b822d6e3fb08d4b38bf2281a4b494d4d156ec48530ecaa64ed2e7532d0d754
JWT_ISSUER=suvidha-auth-service
JWT_CITIZEN_EXPIRY_SECONDS=1800
JWT_ADMIN_EXPIRY_SECONDS=28800

# OTP configuration
OTP_MOCK=true          # Set false in staging/prod to send real SMS
OTP_TTL_SECONDS=300
# Generate with: openssl rand -base64 24
OTP_PEPPER=REPLACE_WITH_32_CHAR_RANDOM_STRING

# Video demo mode: any 6-digit OTP logs in as demo citizen; no real SMS on send (for recording)
VIDEO_DEMO_MODE=true
DEMO_CITIZEN_USER_ID=e0000000-0000-0000-0000-000000000001

# ── 6.4 MeriPehchaan SSO (Admin Login) ──────────────────────────────────
MERIPEHCHAAN_CLIENT_ID=suvidha-hackathon-client
MERIPEHCHAAN_CLIENT_SECRET=REPLACE_WITH_MERIPEHCHAAN_SECRET
MERIPEHCHAAN_BASE_URL=https://meripehchaan.gov.in
ADMIN_CALLBACK_URL=https://admin.suvidha.local/sso/callback

# ── 6.5 SMS / OTP Dispatch ───────────────────────────────────────────────
# Options: MOCK | MSG91 | TWILIO
SMS_PROVIDER=MSG91

# MSG91 (India-based SMS gateway — see docs/MSG91_OTP_CHECKLIST.md for troubleshooting)
MSG91_AUTH_KEY=497234AuHhxofvNht69a34c09P1
MSG91_TEMPLATE_ID=69a34f78c62263e0d50bf024
# If you get "Template ID Missing or Invalid Template", use legacy API only (no template):
MSG91_USE_LEGACY_ONLY=true
# Optional: set if Flow API fails (must match your MSG91/DLT template)
# MSG91_SENDER_ID=
# MSG91_OTP_VAR=OTP

# ── 6.6 BBPS (Bharat Bill Payment System — NPCI) ─────────────────────────
BBPS_BASE_URL=https://uatbbps.billdesk.com/blsagentapi
BBPS_AGENT_ID=REPLACE_WITH_NPCI_ISSUED_AGENT_ID
BBPS_AGENT_SECRET=REPLACE_WITH_BBPS_AGENT_SECRET
BBPS_MOCK=true         # Set false in staging/prod to call real BBPS

# Mutual TLS certificates for BBPS (production only)
BBPS_MTLS_CERT_PATH=/run/secrets/bbps_cert.pem
BBPS_MTLS_KEY_PATH=/run/secrets/bbps_key.pem

# ── 6.7 Bhashini (AI language services — speech-to-text) ─────────────────
BHASHINI_API_KEY=REPLACE_WITH_BHASHINI_API_KEY
BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline
BHASHINI_USER_ID=REPLACE_WITH_BHASHINI_USER_ID
BHASHINI_MOCK=true     # Set false to call real Bhashini ASR

# ── 6.8 DigiLocker (document verification) ───────────────────────────────
DIGILOCKER_CLIENT_ID=REPLACE_WITH_NIC_ISSUED_CLIENT_ID
DIGILOCKER_CLIENT_SECRET=REPLACE_WITH_DIGILOCKER_SECRET
DIGILOCKER_BASE_URL=https://api.digitallocker.gov.in
DIGILOCKER_MOCK=true

# ── 6.9 Mappls / MapmyIndia (geolocation for complaints) ─────────────────
MAPPLS_API_KEY=REPLACE_WITH_MAPMYINDIA_API_KEY
MAPPLS_BASE_URL=https://atlas.mappls.com/api
MAPPLS_MOCK=true

# ── 6.10 Payment Gateway ──────────────────────────────────────────────────
MERCHANT_VPA=suvidha@billdesk
PAYMENT_GATEWAY_URL=REPLACE_WITH_GATEWAY_URL
PAYMENT_GATEWAY_KEY=REPLACE_WITH_GATEWAY_SECRET
PAYMENT_MOCK=true      # Set false in staging/prod

# ── 6.11 Internal Service URLs (used by API Gateway) ─────────────────────
# These resolve via Docker internal DNS — do not change for local dev
AUTH_SERVICE_URL=http://suvidha-auth:3001
ELECTRICITY_SERVICE_URL=http://suvidha-electricity:3002
GAS_SERVICE_URL=http://suvidha-gas:3003
WATER_SERVICE_URL=http://suvidha-water:3004
MUNICIPAL_SERVICE_URL=http://suvidha-municipal:3005
COMPLAINT_SERVICE_URL=http://suvidha-complaint:3006
PAYMENT_SERVICE_URL=http://suvidha-payment:3007
NOTIFICATION_SERVICE_URL=http://suvidha-notification:3008
DOCUMENT_SERVICE_URL=http://suvidha-document:3009
ANALYTICS_SERVICE_URL=http://suvidha-analytics:3010
REQUEST_SERVICE_URL=http://suvidha-request:3011
CONFIG_SERVICE_URL=http://suvidha-config:3012

# ── 6.12 Frontend (Vite — prefix VITE_ required) ──────────────────────────
# These are baked into the built JS bundle at build time
VITE_API_BASE_URL=http://localhost:3000
VITE_KIOSK_ID=c0000000-0000-0000-0000-000000000001
VITE_ULB_ID=a0000000-0000-0000-0000-000000000001
VITE_DEMO_MODE=true
# Video recording: hides "Skip Login (Test Mode)" on kiosk
VITE_VIDEO_DEMO=true
# Public-scoped Mappls key (only map tiles — no write access)
VITE_MAPPLS_API_KEY=REPLACE_WITH_MAPPLS_PUBLIC_KEY

# ── 6.13 Object Storage (MeghRaj S3-compatible) ───────────────────────────
OBJECT_STORAGE_URL=https://object.meghraj.gov.in
OBJECT_STORAGE_BUCKET=suvidha-receipts
OBJECT_STORAGE_KEY=REPLACE_WITH_OBJECT_STORAGE_KEY
OBJECT_STORAGE_SECRET=REPLACE_WITH_OBJECT_STORAGE_SECRET
